const functions = require('firebase-functions');
const admin = require('firebase-admin');
const nodemailer = require('nodemailer');

admin.initializeApp();

// ========================================
// CONFIGURAÇÃO DE EMAIL (SENDGRID)
// ========================================
const transporter = nodemailer.createTransport({
  host: 'smtp.sendgrid.net',
  port: 587,
  secure: false,
  auth: {
    user: 'apikey',
    pass: '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',
  },
});

// ========================================
// FUNÇÃO 1: ENVIAR CÓDIGO DE VERIFICAÇÃO
// ========================================
exports.enviarCodigoVerificacao = functions.https.onCall(async (data, context) => {
  try {
    const { email } = data;

    if (!email) {
      throw new functions.https.HttpsError('invalid-argument', 'Email é obrigatório');
    }

    const codigo = Math.floor(100000 + Math.random() * 900000).toString();

    await admin.firestore().collection('codigos_verificacao').doc(email).set({
      codigo: codigo,
      timestamp: admin.firestore.FieldValue.serverTimestamp(),
      tentativas: 0,
    });

    const mailOptions = {
      from: '"NotaOK" <noreply@notaok.com>',
      to: email,
      subject: '🔐 Seu código de verificação - NotaOK',
      html: `
        <!DOCTYPE html>
        <html>
        <head>
          <meta charset="UTF-8">
          <style>
            body {
              font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
              background-color: #f5f5f5;
              margin: 0;
              padding: 20px;
            }
            .container {
              max-width: 600px;
              margin: 0 auto;
              background: white;
              border-radius: 16px;
              overflow: hidden;
              box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            }
            .header {
              background: linear-gradient(135deg, #8B5CF6 0%, #7C3AED 100%);
              color: white;
              padding: 40px 20px;
              text-align: center;
            }
            .header h1 {
              margin: 0;
              font-size: 32px;
              font-weight: bold;
            }
            .content {
              padding: 40px 30px;
              text-align: center;
            }
            .code-box {
              background: #f8f9fa;
              border: 2px solid #8B5CF6;
              border-radius: 12px;
              padding: 24px;
              margin: 30px 0;
            }
            .code {
              font-size: 48px;
              font-weight: bold;
              color: #8B5CF6;
              letter-spacing: 8px;
              font-family: 'Courier New', monospace;
            }
            .footer {
              padding: 20px;
              text-align: center;
              background: #f8f9fa;
              color: #666;
              font-size: 14px;
            }
            .warning {
              color: #FF6F00;
              font-weight: 500;
              margin-top: 20px;
            }
          </style>
        </head>
        <body>
          <div class="container">
            <div class="header">
              <h1>🛡️ NotaOK</h1>
              <p style="margin: 10px 0 0; font-size: 18px;">Código de Verificação</p>
            </div>
            
            <div class="content">
              <p style="font-size: 18px; color: #333; margin-bottom: 10px;">
                Olá! 👋
              </p>
              <p style="font-size: 16px; color: #666; line-height: 1.6;">
                Use o código abaixo para verificar seu email no NotaOK:
              </p>
              
              <div class="code-box">
                <div class="code">${codigo}</div>
              </div>
              
              <p style="font-size: 14px; color: #999;">
                Este código é válido por <strong>10 minutos</strong>
              </p>
              
              <p class="warning">
                ⚠️ Não compartilhe este código com ninguém!
              </p>
            </div>
            
            <div class="footer">
              <p>Se você não solicitou este código, ignore este email.</p>
              <p style="margin-top: 10px;">
                © 2024 NotaOK - Gerenciador de Garantias
              </p>
            </div>
          </div>
        </body>
        </html>
      `,
    };

    await transporter.sendMail(mailOptions);

    return {
      success: true,
      message: 'Código enviado com sucesso',
    };
  } catch (error) {
    console.error('Erro ao enviar código:', error);
    throw new functions.https.HttpsError('internal', error.message);
  }
});

// ========================================
// FUNÇÃO 2: VALIDAR CÓDIGO
// ========================================
exports.validarCodigoVerificacao = functions.https.onCall(async (data, context) => {
  try {
    const { email, codigo } = data;

    if (!email || !codigo) {
      throw new functions.https.HttpsError('invalid-argument', 'Email e código são obrigatórios');
    }

    const doc = await admin.firestore().collection('codigos_verificacao').doc(email).get();

    if (!doc.exists) {
      throw new functions.https.HttpsError('not-found', 'Código não encontrado ou expirado');
    }

    const dados = doc.data();

    const timestamp = dados.timestamp.toDate();
    const agora = new Date();
    const diferencaMinutos = (agora - timestamp) / 1000 / 60;

    if (diferencaMinutos > 10) {
      await doc.ref.delete();
      throw new functions.https.HttpsError('expired', 'Código expirado. Solicite um novo.');
    }

    if (dados.tentativas >= 3) {
      await doc.ref.delete();
      throw new functions.https.HttpsError('permission-denied', 'Muitas tentativas. Solicite um novo código.');
    }

    if (dados.codigo !== codigo) {
      await doc.ref.update({
        tentativas: admin.firestore.FieldValue.increment(1),
      });
      throw new functions.https.HttpsError('invalid-argument', 'Código incorreto');
    }

    const userRecord = await admin.auth().getUserByEmail(email);
    await admin.auth().updateUser(userRecord.uid, {
      emailVerified: true,
    });

    await admin.firestore().collection('usuarios').doc(userRecord.uid).update({
      emailVerificado: true,
    });

    await doc.ref.delete();

    return {
      success: true,
      message: 'Email verificado com sucesso!',
    };
  } catch (error) {
    console.error('Erro ao validar código:', error);
    throw new functions.https.HttpsError('internal', error.message);
  }
});
